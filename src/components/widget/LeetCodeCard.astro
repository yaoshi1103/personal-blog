---
import { fetchLeetCodeStats } from "../../utils/leetcode";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

const username = "cranky-antonellifja";
const stats = await fetchLeetCodeStats(username);
---

{stats ? (
  <div class="card-base p-3">
    <div class="text-center">
      <span class="font-medium text-sm">
        <a
          href={`https://leetcode.cn/u/${username}`}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[var(--primary)] transition-colors"
        >
          {i18n(I18nKey.leetcode)}
        </a>
      </span>

      <div class="text-[1.75rem] font-bold text-[var(--primary)] leading-tight mt-1">
        {stats.totalSolved}
      </div>
      <div class="text-[0.65rem] text-neutral-400 dark:text-neutral-500 mb-2.5">
        {i18n(I18nKey.solved)}
      </div>

      <div class="flex gap-1.5 justify-center">
        <span class="inline-flex items-center gap-1 rounded-lg px-2 py-0.5 text-xs
          bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400">
          {i18n(I18nKey.easy)}
          <span class="font-semibold">{stats.easySolved}</span>
        </span>
        <span class="inline-flex items-center gap-1 rounded-lg px-2 py-0.5 text-xs
          bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">
          {i18n(I18nKey.medium)}
          <span class="font-semibold">{stats.mediumSolved}</span>
        </span>
        <span class="inline-flex items-center gap-1 rounded-lg px-2 py-0.5 text-xs
          bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400">
          {i18n(I18nKey.hard)}
          <span class="font-semibold">{stats.hardSolved}</span>
        </span>
      </div>
    </div>
  </div>
) : (
  <></>
)}
